# ============================================================
# lvl2do — variáveis de ambiente (exemplo)
# ============================================================
# Copie este arquivo para .env.local e preencha os valores.
# NÃO coloque chaves reais aqui — este arquivo vai para o Git.
#
# Supabase (NECESSÁRIO)
# Dashboard: Project Settings > API
#   - NEXT_PUBLIC_SUPABASE_URL      => campo "Project URL"
#   - NEXT_PUBLIC_SUPABASE_ANON_KEY => campo "anon public" (Project API keys)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
